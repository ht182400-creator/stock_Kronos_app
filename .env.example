# Kronos Web 应用 - 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============ 后端配置 ============
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

# Kronos 源码路径 (重要!)
KRONOS_REPO_DIR=D:/Work_Area/Kronos

# 模型默认配置
MODEL_DEFAULT=kronos-small
DEVICE=cpu

# HuggingFace 缓存目录
HF_HOME=~/.cache/huggingface

# ============ 前端配置 ============
VITE_API_BASE_URL=http://localhost:8000

# ============ 上传配置 ============
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=52428800
